{
  "productName": "ittybitty",
  "version": "0.2.0",
  "identifier": "ai.fleet.ittybitty",
  "build": {
    "frontendDist": "../webapp/dist",
    "devUrl": "http://localhost:11055",
    "beforeDevCommand": "npm --prefix ../webapp run dev -- --port 11055 --host 127.0.0.1"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ittybitty",
        "width": 1100,
        "height": 750,
        "minWidth": 700,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:11054 ipc: http://ipc.localhost; img-src 'self' data: http://127.0.0.1:11054 blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "resources": ["resources/ittybitty-backend.exe"],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
