# LLM
VIDEOGEN_LLM_PROVIDER=deepseek

# DeepSeek V4 Flash (cloud)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# LM Studio (local OpenAI-compatible server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b

# Stock — pexels (cloud) or localgen / cogvideo alias (Wan 2.2 sidecar)
VIDEOGEN_STOCK_PROVIDER=pexels
PEXELS_API_KEY=...

# LocalGen sidecar (Wan 2.2, 2026 tier). Start: start-localgen.bat
LOCALGEN_BACKEND=wan22-14b
LOCALGEN_PORT=8188
COGVIDEO_URL=http://localhost:8188
# wan22-5b = faster 720p@24fps · cogvideo-2b = legacy only

# Google cloud AI footage — Veo 3.x / Gemini Omni (via google-ai-mcp bridge or direct)
# Bridge (recommended): run google-ai-mcp on :11014, set URL below
GOOGLE_AI_MCP_URL=http://127.0.0.1:11014
# Direct (optional): pip install -e ".[google]"
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_VEO_MODEL=veo-3.1-preview-002
GOOGLE_OMNI_MODEL=gemini-omni-flash
# VIDEOGEN_STOCK_PROVIDER=veo | omni | pexels | localgen

# TTS
VIDEOGEN_TTS_PROVIDER=edge-tts
EDGE_TTS_VOICE=en-US-AriaNeural

# Paths
VIDEOGEN_OUTPUT_DIR=./output
VIDEOGEN_CACHE_DIR=./cache

# Server
VIDEOGEN_PORT=11054
VIDEOGEN_HOST=127.0.0.1
